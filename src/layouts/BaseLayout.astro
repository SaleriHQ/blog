---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import config from "../config.js";

const { pageTitle } = Astro.props;
---

<html lang="zh">
  <head>
    <BaseHead
      title={pageTitle || config.SITE_TITLE}
      description={config.SITE_DESCRIPTION}
    />
  </head>
  <body class="bg-[#f2f5f8]">
    <Header />

    <main
      class="bg-[#fff] text-stone-700 text-[18px] min-h-[95vh] m-auto max-w-[65ch] text-left break-words leading-[1.5] px-4 py-2"
    >
      <slot />
    </main>

    <!-- 全局点击图片放大 Lightbox 模态框 -->
    <div
      id="lightbox"
      class="lightbox"
      style="display: none; opacity: 0; pointer-events: none;"
    >
      <span id="lightbox-close" class="lightbox-close">&times;</span>
      <img id="lightbox-img" src="" alt="preview" />
    </div>
  </body>
</html>

<style is:global>
  .lightbox {
    position: fixed;
    inset: 0;
    background: #000000; /* 纯黑底，彻底消除任何背景白边或透光 */
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99999; /* 足够高的层级，确保覆盖全屏所有内容包括 Header 和其他定位元素 */
    transition: opacity 0.25s ease;
  }

  .lightbox img {
    max-width: 95%;
    max-height: 95vh;
    border-radius: 0.5rem;
    transform: scale(0.95);
    opacity: 0;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lightbox.active img {
    transform: scale(1);
    opacity: 1;
  }

  .lightbox-close {
    position: fixed;
    top: 1.5rem;
    right: 2rem;
    color: white;
    font-size: 3rem;
    font-weight: bold;
    cursor: pointer;
    user-select: none;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
    z-index: 100000;
  }

  .lightbox-close:hover {
    transform: rotate(90deg);
    opacity: 0.8;
  }
</style>

<script>
  // 关闭动画（含竞态保护：记录关闭时的 src，若已被新图替换则不清空）
  function closeLightbox() {
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById(
      "lightbox-img",
    ) as HTMLImageElement;
    if (lightboxImg && lightbox) {
      const srcAtClose = lightboxImg.src; // 记录关闭时的 src
      lightboxImg.style.transform = "scale(0.95)";
      lightboxImg.style.opacity = "0";
      lightbox.style.opacity = "0";
      lightbox.style.pointerEvents = "none";
      setTimeout(() => {
        // 若 src 未被新图替换，才执行清理，避免竞态条件
        if (lightboxImg.src === srcAtClose) {
          lightbox.classList.remove("active");
          lightbox.style.display = "none";
          lightboxImg.src = "";
          lightboxImg.removeAttribute("style");
          document.body.style.overflow = "";
        }
      }, 200);
    }
  }

  // 合并为单个 click 事件代理，避免打开/关闭监听器同时触发产生冲突
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target) return;

    if (target.classList.contains("zoom-image")) {
      // 打开 Lightbox
      const src = target.getAttribute("data-src");
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById(
        "lightbox-img",
      ) as HTMLImageElement;

      if (src && lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.style.display = "flex";
        lightbox.offsetHeight; // 触发重绘，确保 transition 生效
        lightbox.style.opacity = "1";
        lightbox.style.pointerEvents = "all";
        lightbox.classList.add("active");
        document.body.style.overflow = "hidden";
      }
    } else if (
      target.id === "lightbox-close" ||
      target.classList.contains("lightbox-close") ||
      target.id === "lightbox"
    ) {
      // 关闭 Lightbox
      closeLightbox();
    }
  });

  // 按 Esc 键关闭
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
