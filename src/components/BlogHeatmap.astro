---
import { getCollection } from "astro:content";
import ActivityCalendar from "./ActivityCalendar";

interface Props {
    title?: string;
}

const { title = "文章更新热力图" } = Astro.props;

const allPosts = await getCollection("blog");

const getUTC8DateString = (date: Date) => {
    return new Intl.DateTimeFormat("en-CA", {
        timeZone: "Asia/Shanghai",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
    }).format(date);
};

const postCount: Record<string, number> = {};
allPosts.forEach((post) => {
    const dateStr = getUTC8DateString(new Date(post.data.pubDate));
    postCount[dateStr] = (postCount[dateStr] || 0) + 1;
});

const heatmapData = [];
const today = new Date();

for (let i = 364; i >= 0; i--) {
    const targetDate = new Date(today.getTime() - i * 24 * 60 * 60 * 1000);
    const dateStr = getUTC8DateString(targetDate);
    const count = postCount[dateStr] || 0;

    let level = 0;
    if (count === 1) level = 1;
    else if (count === 2) level = 2;
    else if (count === 3) level = 3;
    else if (count >= 4) level = 4;

    heatmapData.push({ date: dateStr, count, level });
}
---

<div class="heatmap-card">
    {title && <h3 class="heatmap-title">{title}</h3>}
    <ActivityCalendar
        client:visible
        data={heatmapData}
        theme={{
            light: ["#f2f5f8", "#dbeafe", "#93c5fd", "#60a5fa", "#3b82f6"],
            dark: ["#1e293b", "#1e3a8a", "#2563eb", "#3b82f6", "#60a5fa"],
        }}
        colorScheme="light"
        labels={{
            months: [
                "一月", "二月", "三月", "四月", "五月", "六月",
                "七月", "八月", "九月", "十月", "十一月", "十二月"
            ],
            weekdays: ["日", "一", "二", "三", "四", "五", "六"],
            totalCount: `过去一年共更新 {{count}} 篇文章`,
            legend: {
                less: "少",
                more: "多",
            },
        }}
        fontSize={12}
        blockSize={8}
        blockMargin={2}
        blockRadius={2}
    />
</div>

<style is:global>
    .heatmap-card {
        background-color: transparent;
        border: none;
        border-radius: 0;
        padding: 0;
        margin: 2rem 0;
        box-shadow: none;
        width: 100%;
    }

    .heatmap-title {
        font-size: 1rem;
        font-weight: 500;
        color: #475569;
        margin-top: 0;
        margin-bottom: 1.25rem;
        text-align: left;
    }

    /* Force the component and its scroll container to span 100% of the parent width */
    .heatmap-card .react-activity-calendar {
        width: 100% !important;
        max-width: 100% !important;
    }

    .heatmap-card .react-activity-calendar__scroll-container {
        width: 100% !important;
        max-width: 100% !important;
        overflow-x: hidden !important; /* Hide scrollbars completely since SVG matches container width */
        padding-bottom: 0.5rem;
    }

    /* Force the SVG itself to take up 100% width of the scroll container, scaling automatically */
    .heatmap-card .react-activity-calendar svg {
        width: 100% !important;
        height: auto !important;
    }
</style>
