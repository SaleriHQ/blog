---
import fs from "fs";
import path from "path";
import ImageGrid from "../components/ImageGrid.astro";
import ImageLayout from "../layouts/ImageLayout.astro";

// 自动导入图片
const imageModules = import.meta.glob(
  "../content/gallery/*.{jpg,jpeg,png,webp,gif,avif}",
  { eager: true, as: "url" }
);

// 读取文件修改时间（mtime）
let images = Object.entries(imageModules).map(([filePath, src]) => {
  let date = new Date(); // 默认使用当前时间
  try {
    const absPath = path.resolve(import.meta.dirname, filePath);
    const stat = fs.statSync(absPath);
    date = stat.mtime; // 文件最后修改时间
  } catch (error) {
    // 如果文件不存在，使用当前时间
    console.warn(`File not found: ${filePath}, using current time instead`);
  }
  const filename = decodeURIComponent(filePath.split("/").pop() ?? "");
  return { src: String(src), alt: filename, date };
});

// 按修改时间从新到旧排序
images.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<ImageLayout>
  <ImageGrid images={images} />
</ImageLayout>
