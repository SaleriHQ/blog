---
import BaseLayout from "../layouts/BaseLayout.astro";
import EveryCard from "../components/EveryCard.astro";
import { getCollection, render } from "astro:content";

// 获取 all posts
const posts = await getCollection("every");

// 按发布日期从新到旧排序
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// 自动导入画廊图片以便解析文件名
const imageModules = import.meta.glob(
  "../content/gallery/*.{jpg,jpeg,png,webp,gif,avif}",
  { eager: true, as: "url" }
);

// 解析文件名映射
const resolveImage = (filename: string) => {
  const match = Object.entries(imageModules).find(([key]) =>
    key.endsWith(filename)
  );
  return match ? String(match[1]) : "";
};
---

<BaseLayout pageTitle="Every - 个人动态">
  <div class="py-10 max-w-[65ch] mx-auto font-light">
    <!-- 页面标题 -->
    <h1 class="text-3xl font-bold text-neutral-800 tracking-wide mb-10 border-b border-neutral-200/50 pb-4">
      Every
    </h1>

    <!-- 动态时间轴容器 -->
    <div class="timeline-container relative pl-2">
      {posts.length > 0 ? (
        posts.map(async (post) => {
          const { Content } = await render(post);
          const resolvedImages = (post.data.images || []).map((img) =>
            resolveImage(img)
          ).filter(Boolean);

          return (
            <EveryCard pubDate={post.data.pubDate} images={resolvedImages}>
              <Content />
            </EveryCard>
          );
        })
      ) : (
        <p class="text-neutral-400 text-center py-10 font-light">
          暂无动态，多去生活，多去记录吧。
        </p>
      )}
    </div>
  </div>

  <!-- 点击图片放大 Lightbox 模态框 -->
  <div id="lightbox" class="lightbox" style="display: none; opacity: 0; pointer-events: none;">
    <span id="lightbox-close" class="lightbox-close">&times;</span>
    <img id="lightbox-img" src="" alt="preview" />
  </div>
</BaseLayout>

<style>
  /* ===== 模态框（大图预览） ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
    transition: opacity 0.3s ease;
  }

  .lightbox img {
    max-width: 90%;
    max-height: 90vh;
    border-radius: 0.75rem;
    transform: scale(0.95);
    opacity: 0;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .lightbox.active img {
    transform: scale(1);
    opacity: 1;
  }

  .lightbox-close {
    position: fixed;
    top: 1.5rem;
    right: 2rem;
    color: white;
    font-size: 3rem;
    font-weight: bold;
    cursor: pointer;
    user-select: none;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .lightbox-close:hover {
    transform: rotate(90deg);
    opacity: 0.8;
  }
</style>

<script>
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const closeBtn = document.getElementById("lightbox-close");

  // 使用事件代理处理所有动态生成卡片中的图片点击
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target && target.classList.contains("zoom-image")) {
      const src = target.getAttribute("data-src");
      if (src && lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.style.display = "flex";
        // 触发重绘
        lightbox.offsetHeight;
        lightbox.style.opacity = "1";
        lightbox.style.pointerEvents = "all";
        lightbox.classList.add("active");
      }
    }
  });

  // 关闭动画
  function closeLightbox() {
    if (lightboxImg && lightbox) {
      lightboxImg.style.transform = "scale(0.95)";
      lightboxImg.style.opacity = "0";
      lightbox.style.opacity = "0";
      lightbox.style.pointerEvents = "none";
      setTimeout(() => {
        lightbox.classList.remove("active");
        lightbox.style.display = "none";
        lightboxImg.src = "";
        lightboxImg.removeAttribute("style");
      }, 200);
    }
  }

  closeBtn?.addEventListener("click", closeLightbox);

  // 点击模态框空白处关闭
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // 按 Esc 键关闭
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
